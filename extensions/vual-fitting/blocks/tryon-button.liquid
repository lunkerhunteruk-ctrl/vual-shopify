{% comment %}
  VUAL Fitting — Virtual Try-On Button
  Theme App Extension block for product pages.
  Renders a "Try On" button that opens a modal for virtual try-on.
{% endcomment %}

{% if product and product.tags contains 'vual-tryon' %}
<div id="vual-fitting-root"
     data-product-title="{{ product.title | escape }}"
     data-product-image="{{ product.featured_image | image_url: width: 1024 }}"
     data-product-id="{{ product.id }}"
     data-variant-id="{{ product.selected_or_first_available_variant.id }}"
     data-proxy-url="/apps/vual-fitting"
     data-locale="{{ request.locale.iso_code }}"
     data-category="{{ block.settings.garment_category }}"
     data-product-type="{{ product.type | downcase | escape }}"
     style="display:none; margin: {{ block.settings.margin_top }}px 0 {{ block.settings.margin_bottom }}px;">

  <button id="vual-fitting-trigger"
          class="vual-fitting-btn"
          type="button"
          style="
            background-color: {{ block.settings.button_color }};
            color: {{ block.settings.button_text_color }};
            border-radius: {{ block.settings.button_radius }}px;
            width: {{ block.settings.button_width }};
            font-size: {{ block.settings.button_font_size }}px;
          ">
    <svg class="vual-fitting-btn__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 2a3 3 0 0 0-3 3v1H6a2 2 0 0 0-2 2v1.5a.5.5 0 0 0 .5.5H6l1 11a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2l1-11h1.5a.5.5 0 0 0 .5-.5V8a2 2 0 0 0-2-2h-3V5a3 3 0 0 0-3-3z"/>
      <path d="M9 14l2 2 4-4"/>
    </svg>
    <span class="vual-fitting-btn__text">
      {% if request.locale.iso_code == 'ja' %}
        {{ block.settings.button_text_ja }}
      {% else %}
        {{ block.settings.button_text_en }}
      {% endif %}
    </span>
    <span id="vual-fitting-badge" class="vual-fitting-btn__badge"></span>
  </button>

  <div id="vual-fitting-modal" class="vual-fitting-modal" aria-hidden="true"></div>
</div>

{{ 'vual-fitting.css' | asset_url | stylesheet_tag }}
<script src="{{ 'vual-fitting.js' | asset_url }}" defer></script>
{% endif %}

{% schema %}
{
  "name": "VUAL Try-On",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "button_text_en",
      "label": "Button text (EN)",
      "default": "Virtual Try-On"
    },
    {
      "type": "text",
      "id": "button_text_ja",
      "label": "Button text (JA)",
      "default": "バーチャル試着"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Button color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "button_radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "label": "Button corner radius",
      "default": 8
    },
    {
      "type": "range",
      "id": "button_font_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Button font size",
      "default": 14
    },
    {
      "type": "select",
      "id": "button_width",
      "label": "Button width",
      "options": [
        { "value": "auto", "label": "Auto" },
        { "value": "100%", "label": "Full width" }
      ],
      "default": "100%"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Margin top",
      "default": 8
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Margin bottom",
      "default": 8
    },
    {
      "type": "select",
      "id": "garment_category",
      "label": "Garment category",
      "options": [
        { "value": "upper_body", "label": "Tops" },
        { "value": "lower_body", "label": "Bottoms" },
        { "value": "dresses", "label": "Dresses" },
        { "value": "footwear", "label": "Footwear" }
      ],
      "default": "upper_body"
    }
  ]
}
{% endschema %}
